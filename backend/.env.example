SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-sandbox-storefront-access-token
SHOPIFY_API_VERSION=2024-10
DASHBOARD_BASE_URL=https://your-dashboard-url.com
SHOPIFY_WEBHOOK_SECRET=your-webhook-signing-secret

# ── uAgent config ──
SHOPIFY_AGENT_SEED=your-agent-seed-phrase
SHOPIFY_AGENT_PORT=8001
SHOPIFY_AGENT_ENDPOINT=http://localhost:8001/submit

# ── Composio config (Shopify OAuth via Composio) ──
COMPOSIO_API_KEY=your-composio-api-key
SHOPIFY_AUTH_CONFIG_ID=your-composio-shopify-auth-config-id
